    <div class="d-flex align-items-center">
      <button type="button" class="btn btn-outline-secondary btn-sm theme-toggle">
  
    <i class="bi bi-circle-half"></i>
  
</button>

<script>
  if (!window.themeToggleInitialized) {
    window.themeToggleInitialized = true;

    document.addEventListener('DOMContentLoaded', function() {
      const buttons = document.querySelectorAll('.theme-toggle');
      const currentTheme = 'system';
      const themes = ['light', 'dark', 'system'];

      function handleThemeToggle(e) {
        e.preventDefault();
        e.stopPropagation();

        const currentIndex = themes.indexOf(currentTheme);
        const nextTheme = themes[(currentIndex + 1) % themes.length];

        fetch('/set-theme/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-CSRFToken': 'O6qR0C1fS7mfjjSbdfS2mwQgxcL0SdeZ4Ehi2DbHlBX2v5fsRfSSBtN1JhLAOvQC'
          },
          body: `theme=${nextTheme}`
        }).then(() => window.location.reload());
      }

      buttons.forEach(button => button.addEventListener('click', handleThemeToggle));
    });
  }
</script>

      <button class="navbar-toggler ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavbar" aria-controls="mobileNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
