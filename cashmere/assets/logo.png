          <a href="/terms-of-service/" class="text-decoration-none">Terms of Service</a>
        </p>
      </div>
    </div>
  </div>
</footer>

    <script>
 window.BtConfig = {
   THEME: 'system',
   ENV: 'production',
   STATIC_HOST: 'https://booktalk-static.nyc3.cdn.digitaloceanspaces.com',
 }
 function resolveSystemTheme() {
   if (window.BtConfig.THEME === 'system') {
     const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
     const resolvedTheme = prefersDark ? 'dark' : 'light';
     document.documentElement.setAttribute('data-bs-theme', resolvedTheme);
     window.BtConfig.THEME = resolvedTheme;
   }
 }
 resolveSystemTheme();
 window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', resolveSystemTheme);
 window.BtTooltips = () => {
   // small delay to ensure DOM is fully rendered
   const timer = setTimeout(() => {
     const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
     const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl =>
       new window.bootstrap.Tooltip(tooltipTriggerEl)
     );
     // Tear them down when the components get unmounted if it happens
     return () => {
       tooltipList.forEach(tooltip => tooltip.dispose());
     };
   }, 100);
   return () => clearTimeout(timer);
 };
 // init all tooltips on the screen
 window.BtTooltips();
</script>

    
  </body>
</html>
