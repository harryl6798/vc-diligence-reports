    <div class="toast-container position-fixed top-0 end-0 p-3"></div>
<script>
 function showToast(message, style) {
   if (!style) {
     style = 'primary';
   }
   const styleClasses = {
     primary: 'text-bg-primary',
     secondary: 'text-bg-secondary',
     success: 'text-bg-success',
     error: 'text-bg-success',
     warning: 'text-bg-warning',
     info: 'text-bg-info',
     danger: 'text-bg-danger',
   };
   var toastContainer = document.createElement('div');
   toastContainer.className = `toast align-items-center border-0 ${styleClasses[style]}`;
   toastContainer.role = 'alert';
   toastContainer.ariaLive = 'assertive';
   toastContainer.ariaAtomic = 'true';
   var toastBody = document.createElement('div');
   toastBody.className = 'd-flex';
   toastBody.innerHTML = `
     <div class="toast-body">${message}</div>
     <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
   `;
   toastContainer.appendChild(toastBody);
   document.querySelector('.toast-container').appendChild(toastContainer);
   var toast = new bootstrap.Toast(toastContainer);
   toast.show();
 }

 window.BtShowToast = showToast;

 
</script>

